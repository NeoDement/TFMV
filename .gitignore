# OS
.DS_Store

# Local runtime / user data that shouldn't leak into the repo
# (TFMV writes to its own config/cached dirs under bin/ at runtime — those
# are already excluded by bin/ above, but just in case someone adds a
# top-level one later)
/config/
/cached/
/tmp/
/tmp_loadout/
/tmp_workshop_zip/
/cubemaps/

# TFMV-specific: never commit API keys
**/api_key.ini

# Crash/log dumps
*.log
*.pdb.gz
*.dmp

# Editor backups
*~
*.bak
*.swp

# Claude Code local settings
.claude/